{
    "name": "tts-electron",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "main": "electron/main.js",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "electron": "electron .",
        "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron\"",
        "build:electron": "npm run build && electron-builder",
        "postinstall": "electron-builder install-app-deps"
    },
    "build": {
        "productName": "TTS Electron App",
        "appId": "com.tts.electron",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "electron/**/*",
            "package.json"
        ],
        "extraMetadata": {
            "main": "electron/main.js"
        },
        "asar": true,
        "win": {
            "target": "nsis",
            "icon": "public/icon.ico"
        }
    },
    "dependencies": {
        "@react-oauth/google": "^0.12.2",
        "@reduxjs/toolkit": "^2.8.2",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.1.0",
        "@testing-library/user-event": "^13.2.1",
        "compose": "^0.1.2",
        "doker": "^0.0.8",
        "express": "^5.2.1",
        "nginx": "^1.1.0",
        "number-to-words-ru": "^2.4.1",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-qrcode-logo": "^4.0.0",
        "react-redux": "^9.2.0",
        "react-responsive": "^10.0.1",
        "react-router-dom": "^7.6.3",
        "react-scripts": "5.0.1",
        "redux": "^5.0.1",
        "reselect": "^5.1.1",
        "tmi.js": "^1.8.5",
        "vite-plugin-svgr": "^5.2.0",
        "vklive-message-client": "^5.3.2",
        "web-vitals": "^2.1.0",
        "yarn": "^1.22.22"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "concurrently": "^9.2.1",
        "css-loader": "^7.1.2",
        "electron": "^41.2.2",
        "electron-builder": "^26.8.1",
        "eslint": "^9.39.4",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "postcss-loader": "^8.1.1",
        "sass": "^1.89.2",
        "sass-loader": "^16.0.5",
        "vite": "^8.0.9",
        "wait-on": "^9.0.5"
    }
}
